# =============================================================================
# API Server Configuration
# =============================================================================

# Server
NODE_ENV=development
PORT=4000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_dev

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Meilisearch
# =============================================================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# =============================================================================
# JWT Authentication (RS256)
# =============================================================================
# Generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# =============================================================================
# OAuth — Google
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# =============================================================================
# OAuth — Apple
# =============================================================================
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# =============================================================================
# reCAPTCHA
# =============================================================================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_V3_THRESHOLD=0.5

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# AWS (S3 for file uploads)
# =============================================================================
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================================
# Email (SendGrid — Phase 2)
# =============================================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# =============================================================================
# SMS (Twilio/Unifonic — Phase 2)
# =============================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN_STOREFRONT=http://localhost:3000
CORS_ORIGIN_ADMIN=http://localhost:3001
